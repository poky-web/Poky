import pygame
import random
import sys

# Инициализация Pygame
pygame.init()

# Константы
SCREEN_WIDTH = 400
SCREEN_HEIGHT = 600
GRAVITY = 0.25
BIRD_JUMP = -6
PIPE_SPEED = 3
PIPE_GAP = 150

# Настройка экрана
screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))
clock = pygame.time.Clock()
font = pygame.font.SysFont("Arial", 32)

# Загрузка текстур (замени пути на свои файлы)
try:
    bg_surface = pygame.image.load('background.png').convert()
    bird_surface = pygame.image.load('bird.png').convert_alpha()
    pipe_surface = pygame.image.load('pipe.png').convert_alpha()
    base_surface = pygame.image.load('base.png').convert()
except FileNotFoundError:
    # Заглушки, если файлов нет
    bg_surface = pygame.Surface((SCREEN_WIDTH, SCREEN_HEIGHT))
    bg_surface.fill((135, 206, 235))
    bird_surface = pygame.Surface((34, 24))
    bird_surface.fill((255, 255, 0))
    pipe_surface = pygame.Surface((52, 400))
    pipe_surface.fill((0, 255, 0))
    base_surface = pygame.Surface((SCREEN_WIDTH, 100))
    base_surface.fill((222, 184, 135))

class Bird:
    def __init__(self):
        self.rect = bird_surface.get_rect(center=(50, SCREEN_HEIGHT // 2))
        self.movement = 0

    def update(self):
        self.movement += GRAVITY
        self.rect.centery += self.movement

    def jump(self):
        self.movement = BIRD_JUMP

    def draw(self):
        screen.blit(bird_surface, self.rect)

class Pipe:
    def __init__(self, x):
        self.gap_y = random.randint(150, 450)
        self.rect_top = pipe_surface.get_rect(midbottom=(x, self.gap_y - PIPE_GAP // 2))
        self.rect_bottom = pipe_surface.get_rect(midtop=(x, self.gap_y + PIPE_GAP // 2))
        
        # Логика движения труб вверх-вниз
        self.is_moving = random.random() > 0.5  # 50% шанс, что труба будет двигаться
        self.direction = 1 if random.random() > 0.5 else -1
        self.move_speed = 2

    def update(self):
        # Движение влево
        self.rect_top.centerx -= PIPE_SPEED
        self.rect_bottom.centerx -= PIPE_SPEED

        # Вертикальное движение
        if self.is_moving:
            self.rect_top.centery += self.direction * self.move_speed
            self.rect_bottom.centery += self.direction * self.move_speed
            
            # Меняем направление при достижении границ
            if self.rect_top.bottom >= 450 - PIPE_GAP // 2 or self.rect_top.bottom <= 150 - PIPE_GAP // 2:
                self.direction *= -1

    def draw(self):
        # Верхняя труба (перевернутая)
        flip_pipe = pygame.transform.flip(pipe_surface, False, True)
        screen.blit(flip_pipe, self.rect_top)
        # Нижняя труба
        screen.blit(pipe_surface, self.rect_bottom)

def check_collision(pipes, bird):
    for pipe in pipes:
        if bird.rect.colliderect(pipe.rect_top) or bird.rect.colliderect(pipe.rect_bottom):
            return False
    if bird.rect.top <= -50 or bird.rect.bottom >= 500:
        return False
    return True

def main():
    bird = Bird()
    pipes = []
    spawn_pipe_event = pygame.USEREVENT
    pygame.time.set_timer(spawn_pipe_event, 1200)
    
    score = 0
    game_active = True

    while True:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                pygame.quit()
                sys.exit()
            if event.type == pygame.KEYDOWN:
                if event.key == pygame.K_SPACE and game_active:
                    bird.jump()
                if event.key == pygame.K_SPACE and not game_active:
                    game_active = True
                    pipes.clear()
                    bird = Bird()
                    score = 0
            if event.type == spawn_pipe_event and game_active:
                pipes.append(Pipe(SCREEN_WIDTH + 100))

        # Отрисовка фона
        screen.blit(bg_surface, (0, 0))

        if game_active:
            # Птица
            bird.update()
            bird.draw()

            # Трубы
            for pipe in pipes:
                pipe.update()
                pipe.draw()
                if pipe.rect_top.centerx == 50: # Простое начисление очков
                    score += 1
            
            # Удаление старых труб
            pipes = [pipe for pipe in pipes if pipe.rect_top.right > -50]

            # Проверка столкновений
            game_active = check_collision(pipes, bird)
        else:
            score_surface = font.render(f'Game Over! Score: {int(score)}', True, (255, 255, 255))
            score_rect = score_surface.get_rect(center=(SCREEN_WIDTH//2, SCREEN_HEIGHT//2))
            screen.blit(score_surface, score_rect)

        # Отрисовка земли
        screen.blit(base_surface, (0, 500))
        
        pygame.display.update()
        clock.tick(60)

if __name__ == "__main__":
    main()
