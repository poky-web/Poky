# --- ЗАГРУЗКА АССЕТОВ С УМНЫМ ФИЛЬТРОМ ---
BASE_DIR = os.path.dirname(os.path.abspath(__file__))
IMG_DIR = os.path.join(BASE_DIR, 'assets', 'img')

def load_image(filename, fallback_size, fallback_color):
    path = os.path.join(IMG_DIR, filename)
    if os.path.exists(path):
        # Загружаем картинку
        img = pygame.image.load(path).convert_alpha()
        img = pygame.transform.scale(img, fallback_size)
        
        # Создаем новую пустую поверхность с прозрачностью
        new_img = pygame.Surface(img.get_size(), pygame.SRCALPHA)
        
        # Перебираем каждый пиксель и убираем "мозаику"
        for x in range(img.get_width()):
            for y in range(img.get_height()):
                r, g, b, a = img.get_at((x, y))
                
                # Если пиксель слишком светлый (белый или светло-серый из мозаики)
                # Порог 200 отсекает большинство видов фейковых прозрачностей
                if r > 200 and g > 200 and b > 200:
                    new_img.set_at((x, y), (0, 0, 0, 0)) # Делаем прозрачным
                else:
                    new_img.set_at((x, y), (r, g, b, a)) # Оставляем как есть
                    
        return new_img
    else:
        surf = pygame.Surface(fallback_size)
        surf.fill(fallback_color)
        return surf

# Размеры и картинки
BIRD_SIZE = (34, 24)
